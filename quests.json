  "mainQuests": [
    {
      "id": "mq_01",
      "name": "Un Nouveau Départ",
      "act": 1,
      "order": 1,
      "description": "Vous arrivez dans un village presque abandonné. Le forgeron a besoin de bois pour ranimer la forge.",
      "objectives": [
        {
          "type": "gather",
          "skillId": "woodcutting",
          "actionId": "cut_common",
          "qty": 50,
          "label": "Couper 50 bûches"
