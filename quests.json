      "rewards": {
        "gold": 30,
        "xp": {
          "woodcutting": 200
        },
        "items": [
          {
            "itemId": "tool_axe_iron",
            "qty": 1
          }
        ]
      },
      "unlocks": [
        "mq_02"
      ],
      "lore": "Le village de Valcrest n'est plus que l'ombre de lui-même. Mais peut-être que vous pouvez y changer quelque chose."
    },
